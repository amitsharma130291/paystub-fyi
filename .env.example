# IncomeRecord.com — environment variables
# Copy this file to .env.local and fill in your values.
# .env and .env.local are gitignored.

# -------------------------------------------------------
# Stripe (required for Pro / Business tier payments)
# -------------------------------------------------------
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# -------------------------------------------------------
# Database (required for user accounts / saved stubs)
# -------------------------------------------------------
# DATABASE_URL=postgresql://user:password@host:5432/incomerecord

# -------------------------------------------------------
# Auth (required for dashboard / login)
# -------------------------------------------------------
# AUTH_SECRET=a-random-32-char-string

# -------------------------------------------------------
# Site (set automatically by Astro from astro.config.mjs)
# -------------------------------------------------------
# SITE=https://incomerecord.com
