---
import Base from './Base.astro';

interface Props {
  title: string;
  description: string;
  canonical: string;
  ogImage?: string;
  h1: string;
  date: string;
}

const { title, description, canonical, ogImage, h1, date } = Astro.props;

const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---
<Base title={title} description={description} canonical={canonical} ogImage={ogImage}>
  <article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <header class="mb-8">
      <h1 class="text-4xl font-bold text-gray-900 mb-4">{h1}</h1>
      <time datetime={date} class="text-sm text-gray-500">
        Published {formattedDate}
      </time>
    </header>
    <div class="prose prose-lg max-w-none text-gray-700 leading-relaxed">
      <slot />
    </div>
  </article>
</Base>
