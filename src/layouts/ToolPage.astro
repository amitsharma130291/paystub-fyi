---
import Base from './Base.astro';
import TrustBar from '../components/TrustBar.astro';
import PayStubForm from '../components/PayStubForm';

interface Props {
  title: string;
  description: string;
  canonical: string;
  ogImage?: string;
  h1: string;
  subtitle?: string;
  stateName?: string;
  stateRate?: string;
  defaultState?: string;
}

const { title, description, canonical, ogImage, h1, subtitle, stateName, stateRate, defaultState = 'CA' } = Astro.props;
---
<Base title={title} description={description} canonical={canonical} ogImage={ogImage}>
  <!-- Trust bar -->
  <div class="trust-bar">
    ⭐ Trusted by 10,000+ gig workers, freelancers &amp; small businesses across all 50 states
  </div>

  {stateName && stateRate && (
    <div style="background:#f0fdf4; border-bottom:1px solid #bbf7d0; padding:0.625rem 0; text-align:center; font-size:0.8rem; color:#166534; font-weight:500;">
      ✅ Calculating {stateName} state income tax at {stateRate}% (2024 rate)
    </div>
  )}

  <div style="max-width:900px; margin:0 auto; padding:2rem 1.5rem 4rem;">
    <!-- Breadcrumb -->
    <nav style="font-size:0.875rem; color:#6b7280; margin-bottom:2rem; display:flex; align-items:center; gap:0.5rem;">
      <a href="/" style="color:#1a56db; text-decoration:none; font-weight:500;">Home</a>
      <span style="color:#d1d5db;">›</span>
      <span style="color:#6b7280;">{h1}</span>
    </nav>

    <!-- Hero section -->
    <div style="text-align:center; padding:1rem 0 2rem; max-width:760px; margin:0 auto;">
      <div style="display:inline-block; background:#eff6ff; color:#1e40af; font-size:0.8rem; font-weight:600; padding:0.375rem 0.875rem; border-radius:9999px; margin-bottom:1.25rem; border:1px solid #bfdbfe;">
        Free · No sign-up · Instant PDF
      </div>
      <h1 style="font-size:2rem; font-weight:800; color:#111827; margin-bottom:0.625rem; line-height:1.2; letter-spacing:-0.02em;">{h1}</h1>
      {subtitle && (
        <p style="font-size:1.0625rem; color:#6b7280; margin-bottom:0; line-height:1.6;">{subtitle}</p>
      )}
    </div>

    <!-- Form area -->
    <div style="margin-bottom:3rem;">
      <slot name="form" />
      <PayStubForm client:load defaultState={defaultState} />
    </div>

    <!-- Content -->
    <div class="prose" style="max-width:800px; line-height:1.75; color:#374151;">
      <slot />
    </div>
  </div>
</Base>
