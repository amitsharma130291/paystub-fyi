---
interface Props {
  compact?: boolean;
}
const { compact = false } = Astro.props;
---
<div style={`background:#f0f9ff; border-bottom:1px solid #bfdbfe; padding:${compact ? '0.5rem' : '0.625rem'} 0; text-align:center; font-size:0.875rem; color:#1e40af; font-weight:500; display:flex; align-items:center; justify-content:center; gap:0; flex-wrap:wrap;`}>
  <span><span style="font-size:18px;">🔒</span> No account required</span>
  <span style="margin:0 0.875rem; color:#bfdbfe; font-size:18px;">|</span>
  <span><span style="font-size:18px;">📄</span> Instant PDF</span>
  <span style="margin:0 0.875rem; color:#bfdbfe; font-size:18px;">|</span>
  <span><span style="font-size:18px;">✅</span> 2024 federal &amp; state tax rates</span>
  <span style="margin:0 0.875rem; color:#bfdbfe; font-size:18px;">|</span>
  <span><span style="font-size:18px;">🆓</span> Always free</span>
</div>
