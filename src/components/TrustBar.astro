---
interface Props {
  compact?: boolean;
}
const { compact = false } = Astro.props;
---
<div style={`background:#eff6ff; border-bottom:1px solid #bfdbfe; padding:${compact ? '0.5rem' : '0.625rem'} 0; text-align:center; font-size:0.8rem; color:#1e40af; font-weight:500;`}>
  🔒 No account required
  <span style="margin:0 0.75rem; color:#bfdbfe;">|</span>
  📄 Instant PDF
  <span style="margin:0 0.75rem; color:#bfdbfe;">|</span>
  ✅ 2024 federal &amp; state tax rates
  <span style="margin:0 0.75rem; color:#bfdbfe;">|</span>
  🆓 Always free
</div>
