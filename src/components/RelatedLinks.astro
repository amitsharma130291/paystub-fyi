---
interface Props {
  links: Array<{ href: string; title: string; description?: string; }>;
  heading?: string;
}
const { links, heading = 'Related Tools' } = Astro.props;
---
{links && links.length > 0 && (
  <section style="margin-top:3rem;">
    <h2 style="font-size:1.25rem; font-weight:700; color:#111827; margin-bottom:1.25rem;">{heading}</h2>
    <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(200px, 1fr)); gap:0.875rem;">
      {links.map(link => (
        <a href={link.href}
           style="display:block; background:white; border:1px solid #e5e7eb; border-radius:0.75rem; padding:1rem; text-decoration:none; color:inherit;"
           onmouseover="this.style.borderColor='#1a56db'"
           onmouseout="this.style.borderColor='#e5e7eb'">
          <div style="font-weight:600; font-size:0.9375rem; color:#111827; margin-bottom:0.25rem;">{link.title}</div>
          {link.description && <div style="font-size:0.8125rem; color:#6b7280;">{link.description}</div>}
          <div style="color:#1a56db; font-size:0.8125rem; margin-top:0.5rem;">&rarr;</div>
        </a>
      ))}
    </div>
  </section>
)}
