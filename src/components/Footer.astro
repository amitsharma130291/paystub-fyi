---
<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div>
        <div class="footer-logo">IncomeRecord<span>.com</span></div>
        <p class="footer-tagline">
          Free pay stub generator for gig workers, freelancers, and employees. No account required, no watermarks, instant PDF download.
        </p>
        <div style="margin-top:1.25rem;font-size:0.8rem;color:#6b7280;line-height:1.8;">
          🔒 No data stored<br/>
          📄 Instant PDF download<br/>
          ✅ 2024 federal &amp; state tax rates<br/>
          🆓 Always free
        </div>
      </div>
      <div>
        <div class="footer-heading">Tools</div>
        <ul class="footer-links">
          {tools.map(l => (
            <li><a href={l.href}>{l.label}</a></li>
          ))}
        </ul>
      </div>
      <div>
        <div class="footer-heading">Learn</div>
        <ul class="footer-links">
          {resources.map(l => (
            <li><a href={l.href}>{l.label}</a></li>
          ))}
        </ul>
      </div>
      <div>
        <div class="footer-heading">By State</div>
        <ul class="footer-links">
          {states.map(l => (
