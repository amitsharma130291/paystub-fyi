---
const tools = [
  { href: '/', label: 'Free Pay Stub Generator' },
  { href: '/self-employed-pay-stub-generator', label: 'Self-Employed' },
  { href: '/doordash-pay-stub-generator', label: 'DoorDash Drivers' },
  { href: '/uber-pay-stub-generator', label: 'Uber Drivers' },
  { href: '/pay-stub-for-apartment', label: 'For Apartment' },
  { href: '/proof-of-income-generator', label: 'Proof of Income' },
];
const resources = [
  { href: '/blog/what-is-a-pay-stub', label: 'What Is a Pay Stub?' },
  { href: '/blog/how-to-read-a-pay-stub', label: 'How to Read a Pay Stub' },
  { href: '/pay-stub-template', label: 'Free Templates' },
  { href: '/blog/quarterly-taxes-freelancer', label: 'Quarterly Tax Guide' },
];
const states = [
  { href: '/california-pay-stub-generator', label: 'California' },
  { href: '/texas-pay-stub-generator', label: 'Texas' },
  { href: '/new-york-pay-stub-generator', label: 'New York' },
  { href: '/florida-pay-stub-generator', label: 'Florida' },
  { href: '/illinois-pay-stub-generator', label: 'Illinois' },
];
const company = [
  { href: '/about', label: 'About' },
  { href: '/faq', label: 'FAQ' },
  { href: '/pricing', label: 'Pricing' },
  { href: '/privacy', label: 'Privacy Policy' },
  { href: '/terms', label: 'Terms of Service' },
];
---
<footer style="background:#111827; color:#9ca3af; margin-top:4rem;">
  <div class="container" style="padding-top:3rem; padding-bottom:3rem;">
    <div class="footer-grid" style="display:grid; grid-template-columns:2fr 1fr 1fr 1fr 1fr; gap:2rem;">
      <div>
        <div style="font-size:1.125rem; font-weight:800; color:white; margin-bottom:0.75rem;">
          IncomeRecord<span style="color:#6b7280;">.com</span>
        </div>
        <p style="font-size:0.875rem; line-height:1.6; margin-bottom:1.5rem; color:#9ca3af;">
          Free pay stub generator for gig workers, freelancers, and employees. No account required, no watermarks, instant PDF download.
        </p>
        <div style="font-size:0.8rem; color:#6b7280; line-height:1.8;">
          🔒 No data stored<br/>
          📄 Instant PDF download<br/>
          ✅ 2024 federal &amp; state tax rates<br/>
          🆓 Always free
        </div>
      </div>
      <div>
        <div style="font-size:0.75rem; font-weight:700; color:white; margin-bottom:1rem; text-transform:uppercase; letter-spacing:0.08em;">Tools</div>
        {tools.map(l => (
          <div style="margin-bottom:0.5rem;">
            <a href={l.href} style="font-size:0.875rem; color:#9ca3af; text-decoration:none;">{l.label}</a>
          </div>
        ))}
      </div>
      <div>
        <div style="font-size:0.75rem; font-weight:700; color:white; margin-bottom:1rem; text-transform:uppercase; letter-spacing:0.08em;">Learn</div>
        {resources.map(l => (
          <div style="margin-bottom:0.5rem;">
            <a href={l.href} style="font-size:0.875rem; color:#9ca3af; text-decoration:none;">{l.label}</a>
          </div>
        ))}
      </div>
      <div>
        <div style="font-size:0.75rem; font-weight:700; color:white; margin-bottom:1rem; text-transform:uppercase; letter-spacing:0.08em;">By State</div>
        {states.map(l => (
          <div style="margin-bottom:0.5rem;">
            <a href={l.href} style="font-size:0.875rem; color:#9ca3af; text-decoration:none;">{l.label}</a>
          </div>
        ))}
        <a href="/pay-stub-requirements-by-state" style="font-size:0.75rem; color:#4b5563;">View all 50 states &rarr;</a>
      </div>
      <div>
        <div style="font-size:0.75rem; font-weight:700; color:white; margin-bottom:1rem; text-transform:uppercase; letter-spacing:0.08em;">Company</div>
        {company.map(l => (
          <div style="margin-bottom:0.5rem;">
            <a href={l.href} style="font-size:0.875rem; color:#9ca3af; text-decoration:none;">{l.label}</a>
          </div>
        ))}
      </div>
    </div>
    <div style="border-top:1px solid #1f2937; margin-top:2.5rem; padding-top:1.5rem; font-size:0.8rem; text-align:center; color:#6b7280;">
      &copy; 2024 IncomeRecord.com &middot; All rights reserved &middot; Not a substitute for professional tax or legal advice
    </div>
  </div>
</footer>
