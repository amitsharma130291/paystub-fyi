---
import Base from '../layouts/Base.astro';
---
<Base
  title="Pricing -- IncomeRecord.com"
  description="Free pay stub generator with no watermarks. Pro and Business plans coming soon."
  canonical="https://incomerecord.com/pricing"
>
  <!-- Page hero -->
  <section style="background:linear-gradient(135deg,#1a56db 0%,#1e3a8a 100%);padding:4rem 0;text-align:center;">
    <div class="container">
      <div style="display:inline-block;background:rgba(255,255,255,0.15);color:white;font-size:0.8rem;font-weight:600;padding:0.375rem 1rem;border-radius:9999px;margin-bottom:1rem;letter-spacing:0.05em;text-transform:uppercase;">Simple Pricing</div>
      <h1 style="color:white;font-size:2.25rem;font-weight:800;margin-bottom:1rem;line-height:1.2;">Start Free. Upgrade When You Need More.</h1>
      <p style="color:rgba(255,255,255,0.85);font-size:1.125rem;max-width:520px;margin:0 auto;">Generate professional pay stubs for free. No watermarks, no account required.</p>
    </div>
  </section>

  <!-- Pricing cards -->
  <section style="padding:4rem 0;background:#f9fafb;">
    <div class="container">
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:2rem;max-width:1000px;margin:0 auto;align-items:start;">

        <!-- FREE tier -->
        <div style="background:white;border:2px solid #1a56db;border-radius:1.25rem;padding:2rem;box-shadow:0 4px 20px rgba(26,86,219,0.15);position:relative;">
          <div style="position:absolute;top:-1px;left:50%;transform:translateX(-50%);background:#1a56db;color:white;font-size:0.75rem;font-weight:700;padding:0.25rem 1rem;border-radius:0 0 0.5rem 0.5rem;text-transform:uppercase;letter-spacing:0.05em;white-space:nowrap;">Most Popular</div>
          <div style="margin-top:1rem;">
            <h2 style="font-size:1.25rem;font-weight:700;color:#111827;margin-bottom:0.5rem;">Free</h2>
            <div style="font-size:3rem;font-weight:900;color:#1a56db;line-height:1;margin-bottom:0.25rem;">$0</div>
            <div style="color:#6b7280;font-size:0.875rem;margin-bottom:1.5rem;">Forever free</div>
            <a href="/" style="display:block;width:100%;text-align:center;background:#1a56db;color:white;padding:0.875rem;border-radius:0.625rem;font-weight:700;font-size:1rem;text-decoration:none;margin-bottom:1.5rem;box-shadow:0 4px 14px rgba(26,86,219,0.35);">Generate Pay Stub →</a>
            <ul style="list-style:none;padding:0;margin:0;">
              {['Unlimited pay stub generation','No watermarks ever','2024 federal & state tax calculations','All 50 states supported','Instant PDF download','No account required','No credit card needed'].map(f => (
                <li style="display:flex;align-items:flex-start;gap:0.625rem;margin-bottom:0.75rem;font-size:0.9rem;color:#374151;">
                  <span style="color:#10b981;font-weight:800;flex-shrink:0;">✓</span>{f}
                </li>
              ))}
            </ul>
          </div>
        </div>

        <!-- PRO tier -->
        <div style="background:white;border:1px solid #e5e7eb;border-radius:1.25rem;padding:2rem;box-shadow:0 4px 6px rgba(0,0,0,0.07);">
          <div style="display:inline-block;background:#fef3c7;color:#92400e;font-size:0.7rem;font-weight:700;padding:0.25rem 0.75rem;border-radius:9999px;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:1rem;">Coming Soon</div>
          <h2 style="font-size:1.25rem;font-weight:700;color:#111827;margin-bottom:0.5rem;">Pro</h2>
          <div style="font-size:3rem;font-weight:900;color:#111827;line-height:1;margin-bottom:0.25rem;">$9<span style="font-size:1rem;font-weight:400;color:#6b7280;">/mo</span></div>
          <div style="color:#6b7280;font-size:0.875rem;margin-bottom:1.5rem;">Billed monthly</div>
          <div style="display:block;width:100%;text-align:center;background:#f3f4f6;color:#9ca3af;padding:0.875rem;border-radius:0.625rem;font-weight:600;font-size:0.9rem;margin-bottom:1.5rem;cursor:not-allowed;">Coming Soon</div>
          <p style="font-size:0.8rem;color:#6b7280;margin-bottom:1rem;">Everything in Free, plus:</p>
          <ul style="list-style:none;padding:0;margin:0;">
            {['Save stub history (unlimited)','Custom company logo on PDF','Multiple employer profiles','Email PDF directly','Premium PDF template','Priority support'].map(f => (
              <li style="display:flex;align-items:flex-start;gap:0.625rem;margin-bottom:0.75rem;font-size:0.9rem;color:#374151;">
                <span style="color:#d1d5db;font-weight:800;flex-shrink:0;">✓</span>{f}
              </li>
            ))}
          </ul>
        </div>

        <!-- BUSINESS tier -->
        <div style="background:white;border:1px solid #e5e7eb;border-radius:1.25rem;padding:2rem;box-shadow:0 4px 6px rgba(0,0,0,0.07);">
          <div style="display:inline-block;background:#fef3c7;color:#92400e;font-size:0.7rem;font-weight:700;padding:0.25rem 0.75rem;border-radius:9999px;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:1rem;">Coming Soon</div>
          <h2 style="font-size:1.25rem;font-weight:700;color:#111827;margin-bottom:0.5rem;">Business</h2>
          <div style="font-size:3rem;font-weight:900;color:#111827;line-height:1;margin-bottom:0.25rem;">$29<span style="font-size:1rem;font-weight:400;color:#6b7280;">/mo</span></div>
          <div style="color:#6b7280;font-size:0.875rem;margin-bottom:1.5rem;">Billed monthly</div>
          <div style="display:block;width:100%;text-align:center;background:#f3f4f6;color:#9ca3af;padding:0.875rem;border-radius:0.625rem;font-weight:600;font-size:0.9rem;margin-bottom:1.5rem;cursor:not-allowed;">Coming Soon</div>
          <p style="font-size:0.8rem;color:#6b7280;margin-bottom:1rem;">Everything in Pro, plus:</p>
          <ul style="list-style:none;padding:0;margin:0;">
            {['Up to 25 employees','Bulk stub generation','Excel/CSV export','Team member access','API access','Dedicated support'].map(f => (
              <li style="display:flex;align-items:flex-start;gap:0.625rem;margin-bottom:0.75rem;font-size:0.9rem;color:#374151;">
                <span style="color:#d1d5db;font-weight:800;flex-shrink:0;">✓</span>{f}
              </li>
            ))}
          </ul>
        </div>
      </div>

      <div style="text-align:center;margin-top:2.5rem;color:#6b7280;font-size:0.9rem;">
        <span style="margin:0 1rem;">🔒 No credit card ever required for Free</span>
        <span style="margin:0 1rem;">✓ Cancel anytime</span>
        <span style="margin:0 1rem;">📄 Data never sold</span>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section style="padding:4rem 0;background:white;">
    <div class="container" style="max-width:700px;">
      <h2 style="font-size:1.75rem;font-weight:800;text-align:center;margin-bottom:2.5rem;">Pricing FAQ</h2>
      {[
        {q:'Is the Free tier really free?',a:"Yes. IncomeRecord.com's free tier is free forever. No credit card, no trial period, no hidden fees. Generate unlimited pay stubs at no cost."},
        {q:"What's the catch with the free version?",a:'There is no catch. The free version has no watermarks and no generation limits. We plan to add account-based features in paid tiers, but the core generator stays free.'},
        {q:'When will Pro and Business launch?',a:"We're building the account system and Pro features now. The core generator is fully functional today."},
        {q:'Can I use this for my employees?',a:'Yes. The free version works for any number of employees -- just generate a stub for each one. Business tier will add bulk generation.'},
      ].map(item => (
        <div style="border-bottom:1px solid #e5e7eb;padding:1.5rem 0;">
          <div style="font-weight:700;color:#111827;font-size:1rem;margin-bottom:0.75rem;">{item.q}</div>
          <div style="color:#6b7280;font-size:0.9375rem;line-height:1.7;">{item.a}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- Bottom CTA -->
  <section style="background:linear-gradient(135deg,#1a56db 0%,#1e3a8a 100%);padding:4rem 0;text-align:center;">
    <div class="container">
      <h2 style="color:white;font-size:2rem;font-weight:800;margin-bottom:1rem;">Start Generating Pay Stubs Free</h2>
      <p style="color:rgba(255,255,255,0.85);margin-bottom:2rem;">No account. No credit card. Just fill in the form and download.</p>
      <a href="/" style="display:inline-block;background:white;color:#1a56db;padding:1rem 2.5rem;border-radius:0.625rem;font-weight:700;font-size:1.1rem;text-decoration:none;box-shadow:0 4px 14px rgba(0,0,0,0.15);">Generate Free Pay Stub →</a>
    </div>
  </section>
</Base>
